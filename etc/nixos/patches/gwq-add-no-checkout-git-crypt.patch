+func isGitCryptSmudgeError(err error) bool {
+	if err == nil {
+		return false
+	}
+
+	msg := strings.ToLower(err.Error())
+	if !strings.Contains(msg, "git-crypt") {
+		return false
+	}
+
+	return strings.Contains(msg, "smudge") || strings.Contains(msg, "smudge filter")
+}
